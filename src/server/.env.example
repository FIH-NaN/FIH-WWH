# Example environment file.
# Copy this to: FIH-WWH/.env (project root), then fill in actual values.

# Database
DATABASE_URL=sqlite:///./wealth_hub.db

# JWT Secret - CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production-12345

# JWT Algorithm
ALGORITHM=HS256

# Token expiry (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (comma-separated)
CORS_ORIGINS= ["http://localhost:3000","http://localhost:5173"]

# Open AI API Key
OPENAI_API_KEY=your_openai_api_key_here

# MiniMax API (optional; used by AI insights fallback chain)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_API_URL=https://api.minimaxi.com/anthropic/v1/messages

# GoldRush / Covalent API (required for /accounts sync and balances_v2)
GOLDRUSH_API_KEY=your_goldrush_api_key_here

# Plaid (optional unless using plaid provider)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_REDIRECT_URI=

# Optional secret encryption key for plaid tokens
# If empty, backend derives one from SECRET_KEY
PLAID_TOKEN_ENCRYPTION_KEY=

# Sync tuning
SYNC_JOB_TIMEOUT_SECONDS=300
SYNC_MAX_RETRIES=3

WEB3_RPC_URL=your_web3_rpc_url_here