# Copy to .env.docker and fill real secrets for local deployment
SECRET_KEY=change-me-to-a-long-random-string

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_REDIRECT_URI=
PLAID_TOKEN_ENCRYPTION_KEY=

GOLDRUSH_API_KEY=

MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_API_URL=https://api.minimaxi.com/anthropic/v1/messages

# Optional CORS overrides
CORS_ORIGINS=["http://localhost","http://127.0.0.1"]
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$|https://.*\.trycloudflare\.com$
